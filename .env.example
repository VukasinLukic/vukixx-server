# Vukixxx Server Configuration

# Port (Railway auto-sets this, no need to change)
PORT=3777

# AI Provider: "gemini" or "ollama"
AI_PROVIDER=gemini

# Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama URL (required if AI_PROVIDER=ollama, not available on Railway)
OLLAMA_URL=http://localhost:11434

# Firebase Service Account JSON (required)
# Paste the FULL content of your Firebase service account JSON key file
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
